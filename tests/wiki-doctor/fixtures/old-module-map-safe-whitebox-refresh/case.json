{
  "id": "old-module-map-safe-whitebox-refresh",
  "behavior": "old_module_map_refreshes_to_whitebox_source_and_svg",
  "mode": "default",
  "gate": "empty_drift_allows_default",
  "classifications": [
    "safe_guidance_rewrite"
  ],
  "actions": [
    "rewrite_page",
    "add_table_or_diagram"
  ],
  "stable_pages_rewritten": true,
  "whitebox_source": "wiki/04-modules/fulfillment.whitebox.yaml",
  "whitebox_svg": "wiki/04-modules/fulfillment.whitebox.svg",
  "whitebox_derived_svgs": {
    "boundary": "wiki/04-modules/fulfillment.whitebox.boundary.svg",
    "delegation": "wiki/04-modules/fulfillment.whitebox.delegation.svg",
    "assembly": "wiki/04-modules/fulfillment.whitebox.assembly.svg",
    "interfaces": "wiki/04-modules/fulfillment.whitebox.interfaces.svg"
  },
  "module_page": "wiki/04-modules/fulfillment.md",
  "expected_wiki_must_contain": [
    "![Fulfillment Module whitebox component diagram](./fulfillment.whitebox.svg)",
    "Source model: [`fulfillment.whitebox.yaml`](./fulfillment.whitebox.yaml) for the complete diagram and derived views below.",
    "### Boundary Derived Whitebox View",
    "![Fulfillment Module Boundary Derived Whitebox View](./fulfillment.whitebox.boundary.svg)",
    "### Delegation Derived Whitebox View",
    "![Fulfillment Module Delegation Derived Whitebox View](./fulfillment.whitebox.delegation.svg)",
    "### Assembly Derived Whitebox View",
    "![Fulfillment Module Assembly Derived Whitebox View](./fulfillment.whitebox.assembly.svg)",
    "### Interfaces Derived Whitebox View",
    "![Fulfillment Module Interfaces Derived Whitebox View](./fulfillment.whitebox.interfaces.svg)",
    "Derived views are reader aids generated from the same source model; they do not replace the complete diagram.",
    "Checkout flow starts fulfillment through the Submit Fulfillment boundary port.",
    "Returns flow asks Fulfillment through the Cancel Fulfillment boundary port.",
    "Operations console reads fulfillment through the Fulfillment Status boundary port.",
    "Submit Fulfillment is delegated to Order Intake.",
    "Cancel Fulfillment is delegated to Cancellation Desk.",
    "Fulfillment Status is delegated to Status Projector.",
    "Order Intake delegates stock reservation needs to Inventory Client.",
    "Order Intake delegates label purchase needs to Carrier Client.",
    "Order Intake delegates notification dispatch needs to Notifier.",
    "Order Intake passes accepted orders to Order Writer.",
    "Order Writer publishes audit records to Audit Logger.",
    "Manual cancellation follow-up is mentioned as a future boundary candidate, not confirmed.",
    "[Checkout flow](../02-flows/checkout.md)",
    "[Inventory model](../05-models/inventory.md)",
    "Evidence: `src/fulfillment/FulfillmentController.ts`",
    "Evidence: `src/fulfillment/StatusController.ts`",
    "Evidence: `src/fulfillment/OrderIntake.ts`",
    "Evidence: `src/fulfillment/InventoryClient.ts`",
    "Evidence: `src/fulfillment/CarrierClient.ts`",
    "Evidence: `src/fulfillment/Notifier.ts`",
    "Evidence: `src/fulfillment/OrderWriter.ts`",
    "Evidence: `src/fulfillment/AuditLogger.ts`"
  ],
  "expected_wiki_must_not_contain": [
    "Returns Adapter"
  ],
  "whitebox_model_must_contain": [
    "kind: whitebox_component_diagram",
    "id: fulfillment_module",
    "id: submit_fulfillment",
    "id: order_intake",
    "id: inventory_client",
    "type: external",
    "type: delegation",
    "type: assembly",
    "type: interfaceAssembly"
  ],
  "report_must_contain": [
    "Classification: `safe_guidance_rewrite`.",
    "Actions: `rewrite_page`, `add_table_or_diagram`.",
    "Whitebox files refreshed:",
    "Derived Whitebox Views embedded after the complete diagram:"
  ],
  "report_must_not_contain": [
    "meaning_loss_risk",
    "drift_or_coverage_suspect"
  ]
}
